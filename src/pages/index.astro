---
import Layout from '../layouts/Layout.astro';

// --- DATA SECTION ---

const experience = [
  {
    role: "Senior Solutions Engineer",
    company: "Cloudflare",
    period: "February 2022 – Present",
    color: "#F6821F", // Cloudflare Orange
    details: [
      "First SE hired to build and scale Cloudflare's technical footprint in India.",
      "Architect secure, scalable solutions by mapping customer initiatives to modern Cloudflare architectures.",
      "Drive technical strategy with engineering leaders and C-suite stakeholders.",
      "Lead demos, deep-dives, and POCs end-to-end to accelerate adoption.",
      "Represent Cloudflare at industry and cybersecurity events as a technical evangelist."
    ]
  },
  {
    role: "Solutions Engineer II – South",
    company: "F5 Networks",
    period: "February 2020 – February 2022",
    color: "#E83D43", // F5 Red
    details: [
      "Delivered technical leadership across solution designs, demos, and POCs.",
      "Architected advanced F5 configurations enabling new services and solving complex issues.",
      "Positioned F5 competitively with differentiated architectures and CXO-level value messaging.",
      "Presented whiteboards and technical strategy to senior decision-makers."
    ]
  },
  {
    role: "Presales Systems Engineer – South",
    company: "Infoblox",
    period: "June 2019 – February 2020",
    color: "#27AE60", // Infoblox Green
    details: [
      "Drove technical differentiation in sales cycles by educating customers and partners on Infoblox's core DDI and security solutions.",
      "Created high-quality presales content—including presentations, demos, and webinars—to accelerate solution adoption.",
      "Designed end-to-end architectures illustrating how Infoblox integrates with broader enterprise security and networking ecosystems.",
      "Enabled partner technical teams with training and guidance to identify opportunities and effectively position Infoblox solutions."
    ]
  },
  {
    role: "SOCC Specialist – Senior",
    company: "Akamai Technologies",
    period: "August 2017 – June 2019",
    color: "#0099CC", // Akamai Blue
    details: [
      "Protected global customers against DDoS and web attacks using Prolexic and KONA WAF within Akamai GSOC.",
      "Served as global Product Line Expert for Bot Manager and SME for Akamai Platform.",
      "Part of S2ET, the senior escalation layer for complex security incidents across Akamai services.",
      "Delivered real-time attack support—analysing patterns, identifying signatures, and crafting mitigation policies.",
      "Performed proactive and reactive threat analysis to reduce false positives, enhance WAF accuracy, and shrink attack surfaces."
    ]
  },
  {
    role: "Technical Consultant",
    company: "M.TECH",
    period: "May 2017 – August 2017",
    color: "#666666", // Neutral
    details: [
      "Acted as an extended arm to Arbor Networks with their implementation, support, PoCs, demos, and presentations."
    ]
  },
  {
    role: "Technical Head - West",
    company: "Radware",
    period: "August 2013 – April 2017",
    color: "#D32F2F", // Radware Red
    details: [
      "Managed a team of System Engineers – West, and distributor resources.",
      "Owned and delivered complete Pre-sales activities for Radware in west India.",
      "Delivered presentations, demos, design and PoCs of Radware solution and handled critical customer escalation."
    ]
  },
  {
    role: "Field Engineer (Emerging Technologies)",
    company: "Wipro InfoTech",
    period: "December 2009 – August 2013",
    color: "#005C97", // Wipro Blue
    details: [
      "Troubleshot and implemented Load balancers, Proxy Servers, e-Mail Security gateway, IPS/IDS, SSL VPN Gateways, Application Firewall, QOS devices & WAN Optimization devices."
    ]
  }
];

const education = [
  {
    degree: "BS — Information Systems",
    school: "Birla Institute of Technologies and Science"
  },
  {
    degree: "BSc — Information Technology",
    school: "Kuvempu University"
  },
  {
    degree: "Diploma in Information Technology",
    school: "Nettur Technical Training Center"
  }
];

const certifications = [
  "Oracle Cloud Infrastructure 2021 Certified Associate",
  "Radware IAS Engineer",
  "F5 Product Consultant – LTM",
  "Citrix Certified Administrator for Netscaler 9.2"
];

const skills = [
  "WAF & DDoS Mitigation", "Zero Trust Architecture", "CDN & Edge Performance",
  "Programmable Edge", "DDI (DNS/DHCP/IPAM)", "SOC Operations",
  "Application Defense", "APM & Diagnostics", "Network Troubleshooting"
];
---

<Layout title="Tharun Raj | Senior Solutions Engineer">
	<div class="bg-gradient-1"></div>
	<div class="bg-gradient-2"></div>

	<main class="container">
		
		<section class="hero">
			<div class="hero-content fade-in-up">
				<div class="badge">Senior Solutions Engineer</div>
				<h1>Tharun Raj</h1>
				<h2 class="typing-effect">Building the Secure Cloud.</h2>
				<p class="summary">
					Senior Solutions Engineer with 16+ years in application security, cloud networking, and presales leadership. Expert in architecting enterprise-grade solutions, driving technical strategy, and influencing C-suite outcomes across large accounts. Proven track record across Cloudflare, F5, Akamai, Infoblox, and Radware.
				</p>
				<div class="cta-group">
                    <button id="copyEmailBtn" class="btn primary">Contact Me</button>
					<a href="https://www.linkedin.com/in/tharunraj/" target="_blank" class="btn secondary">LinkedIn</a>
				</div>
                <div id="toast" class="toast">Email copied to clipboard!</div>
			</div>
			
			<div class="hero-image fade-in-delayed">
				<div class="image-wrapper">
					<img src="/profile.jpg" alt="Tharun Raj" onerror="this.src='https://ui-avatars.com/api/?name=Tharun+Raj&background=random&size=512'" />
				</div>
			</div>
		</section>

		<section class="skills">
			<h3 class="section-title">Core Skills</h3>
			<div class="skill-grid">
				{skills.map((skill, index) => (
					<div class="skill-tag" style={`animation-delay: ${index * 50}ms`}>{skill}</div>
				))}
			</div>
		</section>

		<section class="experience">
			<h3 class="section-title">Experience</h3>
			<div class="timeline">
				{experience.map((job, index) => (
					<div class="card" style={`--accent-color: ${job.color}; animation-delay: ${index * 100}ms`}>
						<div class="card-header">
							<div>
								<h4>{job.role}</h4>
								<span class="company" style={`color: ${job.color}`}>{job.company}</span>
							</div>
							<span class="period">{job.period}</span>
						</div>
						<ul class="job-details">
							{job.details.map((d) => <li>{d}</li>)}
						</ul>
					</div>
				))}
			</div>
		</section>

		<div class="grid-2-col">
			<section class="education">
				<h3 class="section-title">Education</h3>
				<div class="card-simple-container">
					{education.map((edu) => (
						<div class="card-simple">
							<h4>{edu.degree}</h4>
							<span class="school">{edu.school}</span>
						</div>
					))}
				</div>
			</section>

			<section class="certifications">
				<h3 class="section-title">Certifications</h3>
				<div class="card-simple-container">
					{certifications.map((cert) => (
						<div class="card-simple">
							<span class="cert-icon">🏆</span>
							<span>{cert}</span>
						</div>
					))}
				</div>
			</section>
		</div>

	</main>

    <footer>
        <p>&copy; {new Date().getFullYear()} Tharun Raj. Built with <span style="color: #F6821F">Astro</span> on <span style="color: #F6821F">Cloudflare</span>.</p>
    </footer>

    <script>
        const btn = document.getElementById('copyEmailBtn');
        const toast = document.getElementById('toast');
        const email = "tharun@tharunraj.co.in";

        if (btn && toast) {
            btn.addEventListener('click', () => {
                navigator.clipboard.writeText(email).then(() => {
                    // Show Toast
                    toast.classList.add('show');
                    // Hide after 3 seconds
                    setTimeout(() => {
                        toast.classList.remove('show');
                    }, 3000);
                }).catch(err => {
                    console.error('Failed to copy: ', err);
                });
            });
        }
    </script>
</Layout>

<style>
	/* LAYOUT UTILS */
	.container {
		max-width: 1000px;
		margin: 0 auto;
		padding: 2rem;
		position: relative;
		z-index: 10;
	}
	.grid-2-col {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		margin-top: 3rem;
	}

	/* ANIMATIONS */
	@keyframes fadeInUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
	
	.fade-in-up { animation: fadeInUp 0.8s ease-out forwards; opacity: 0; }
	.fade-in-delayed { animation: fadeInUp 0.8s ease-out 0.3s forwards; opacity: 0; }
	.card { animation: fadeInUp 0.6s ease-out forwards; opacity: 0; }
	.skill-tag { animation: fadeInUp 0.5s ease-out forwards; opacity: 0; }

	/* HERO */
	.hero {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		align-items: center;
		gap: 4rem;
		min-height: 70vh;
		padding-bottom: 4rem;
	}
	.badge {
		background: rgba(255, 255, 255, 0.1);
		color: var(--text-muted);
		padding: 0.5rem 1rem;
		border-radius: 50px;
		font-size: 0.85rem;
		display: inline-block;
		margin-bottom: 1.5rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}
	h1 {
		font-size: 3.5rem;
		line-height: 1.1;
		margin: 0 0 1rem 0;
		background: linear-gradient(to right, #fff, #aaa);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		font-weight: 800;
	}
	h2 {
		font-size: 1.5rem;
		color: var(--text-muted);
		font-weight: 400;
		margin: 0 0 2rem 0;
	}
	.summary {
		font-size: 1.05rem;
		color: #999;
		max-width: 100%;
		margin-bottom: 2.5rem;
		line-height: 1.7;
	}

	/* BUTTONS */
	.cta-group { display: flex; gap: 1rem; }
	.btn {
		padding: 0.8rem 2rem;
		border-radius: 8px;
		font-weight: 600;
		transition: all 0.2s ease;
		text-align: center;
		text-decoration: none;
        cursor: pointer; /* Ensure pointer shows on button */
        font-family: inherit; /* Inherit font from body */
        font-size: 1rem;
        border: none;
	}
	.btn.primary {
		background: white;
		color: black;
	}
	.btn.primary:hover {
		background: #ddd;
		transform: translateY(-2px);
	}
	.btn.secondary {
		background: transparent;
		border: 1px solid #333;
		color: white;
	}
	.btn.secondary:hover {
		border-color: white;
		background: rgba(255,255,255,0.05);
	}

    /* TOAST NOTIFICATION */
    .toast {
        visibility: hidden; 
        min-width: 250px; 
        background-color: #333; 
        color: #fff; 
        text-align: center; 
        border-radius: 50px; 
        padding: 16px; 
        position: fixed; 
        z-index: 100; 
        left: 50%; 
        bottom: 30px; 
        transform: translateX(-50%);
        font-size: 0.9rem;
        border: 1px solid rgba(255,255,255,0.1);
        box-shadow: 0 5px 15px rgba(0,0,0,0.5);
        opacity: 0;
        transition: opacity 0.5s, bottom 0.5s;
    }

    .toast.show {
        visibility: visible;
        opacity: 1;
        bottom: 50px; /* Slight slide up effect */
    }

	/* HERO IMAGE */
	.image-wrapper {
		position: relative;
		width: 320px;
		height: 320px;
		border-radius: 50%;
		overflow: hidden;
		border: 4px solid rgba(255,255,255,0.1);
		box-shadow: 0 0 50px rgba(0,0,0,0.5);
        margin: 0 auto;
	}
	.image-wrapper img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* CARDS */
	.section-title {
		font-size: 1.5rem;
		border-bottom: 1px solid #333;
		padding-bottom: 1rem;
		margin-bottom: 2rem;
		color: #fff;
		margin-top: 3rem;
	}
	.timeline {
		display: grid;
		gap: 1.5rem;
	}
	.card {
		background: var(--card-bg);
		border: 1px solid rgba(255,255,255,0.05);
		padding: 2rem;
		border-radius: 12px;
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.card:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 30px rgba(0,0,0,0.3);
		border-color: rgba(255,255,255,0.1);
	}
	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1rem;
	}
	.card h4 { margin: 0; font-size: 1.25rem; color: #fff; }
	.company { font-weight: 700; font-size: 1rem; display: block; margin-top: 0.25rem; }
	.period { font-size: 0.85rem; color: #888; white-space: nowrap; margin-left: 1rem;}
	.job-details { padding-left: 1.2rem; color: #bbb; font-size: 0.95rem; line-height: 1.6; }
	.job-details li { margin-bottom: 0.5rem; }

	/* SKILLS */
	.skill-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
	}
	.skill-tag {
		background: rgba(255,255,255,0.05);
		padding: 0.5rem 1rem;
		border-radius: 6px;
		font-size: 0.9rem;
		color: #ddd;
		border: 1px solid transparent;
		transition: all 0.3s;
	}
	.skill-tag:hover {
		background: rgba(255,255,255,0.1);
		border-color: rgba(255,255,255,0.2);
	}

	/* SIMPLE CARDS (Education/Certs) */
	.card-simple-container {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.card-simple {
		background: var(--card-bg);
		border: 1px solid rgba(255,255,255,0.05);
		padding: 1.5rem;
		border-radius: 8px;
	}
	.card-simple h4 { margin: 0 0 0.5rem 0; font-size: 1rem; color: #fff; }
	.school { color: #888; font-size: 0.9rem; }
	.cert-icon { margin-right: 0.5rem; }

	/* DECORATION */
	.bg-gradient-1 {
		position: absolute;
		top: -10%;
		right: -10%;
		width: 600px;
		height: 600px;
		background: radial-gradient(circle, rgba(29, 78, 216, 0.15), transparent 70%);
		z-index: 1;
		pointer-events: none;
	}
	.bg-gradient-2 {
		position: absolute;
		bottom: 10%;
		left: -10%;
		width: 500px;
		height: 500px;
		background: radial-gradient(circle, rgba(136, 58, 234, 0.15), transparent 70%);
		z-index: 1;
		pointer-events: none;
	}
    
    footer { text-align: center; padding: 4rem 0; color: #555; font-size: 0.9rem; margin-top: 2rem; }

	/* RESPONSIVE */
	@media (max-width: 768px) {
		.hero { grid-template-columns: 1fr; text-align: center; gap: 2rem; }
		.hero-content { order: 2; }
		.hero-image { order: 1; display: flex; justify-content: center; }
		.image-wrapper { width: 200px; height: 200px; }
		h1 { font-size: 2.5rem; }
		.cta-group { justify-content: center; }
		.card-header { flex-direction: column; gap: 0.5rem; }
		.period { margin-left: 0; }
		.grid-2-col { grid-template-columns: 1fr; }
	}
</style>
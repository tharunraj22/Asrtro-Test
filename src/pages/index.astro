---
import Layout from '../layouts/Layout.astro';

// --- DATA ---
const experience = [
  { role: "Senior Solutions Engineer", company: "Cloudflare", period: "2022 – Present", color: "#F6821F", highlight: "Scaling technical footprint in India & leading C-suite strategy." },
  { role: "Solutions Engineer II", company: "F5 Networks", period: "2020 – 2022", color: "#E83D43", highlight: "Architected advanced configurations for complex issues." },
  { role: "Presales Systems Engineer", company: "Infoblox", period: "2019 – 2020", color: "#27AE60", highlight: "Drove technical differentiation for DDI & security." },
  { role: "SOCC Specialist – Senior", company: "Akamai", period: "2017 – 2019", color: "#0099CC", highlight: "Global DDoS/WAF protection & Bot Manager SME." },
  // Older roles condensed for impact
  { role: "Previous Roles", company: "Radware, Wipro, M.TECH", period: "2009 – 2017", color: "#666", highlight: "Foundational experience in Network Security, Load Balancing, and Pre-sales leadership." }
];

const skillsHighlihgts = ["Zero Trust Architecture", "WAF & DDoS Mitigation", "CDN & Edge Computing", "C-Suite Presales", "Solution Architecture"];
const skillsAll = ["Programmable Edge", "DDI (DNS/DHCP/IPAM)", "SOC Operations", "App Defense", "APM & Diagnostics", "Network Troubleshooting", "BGP/Routing"];

const certs = ["Oracle Cloud Certified Associate", "Radware IAS Engineer", "F5 Product Consultant", "Citrix Certified Admin"];
---

<Layout title="Tharun Raj | Senior Solutions Engineer">
    <div class="noise-bg"></div>
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>

	<main class="bento-grid container fade-in">
		
        <div class="bento-card hero-card" style="grid-area: hero;">
            <div class="hero-content">
                <div class="badge">16+ YOE / Senior Solutions Engineer</div>
                <h1>Tharun Raj</h1>
                <h2>Architecting the Secure Cloud.</h2>
                <p>Translating complex business challenges into scalable, secure edge architectures. Proven track record influencing C-suite outcomes at major enterprises.</p>
                <button id="copyEmailBtn" class="btn-glow">
                    <span>Email Me</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-copy"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
                </button>
            </div>
            <div class="hero-image-container">
                 <img src="/conference.jpg" alt="Tharun Raj Speaking" class="hero-img" onerror="this.src='https://ui-avatars.com/api/?name=TR&background=111&color=fff'"/>
            </div>
		</div>

        <div class="bento-card focus-card" style="grid-area: focus; --accent: #F6821F;">
            <div class="card-label">Current Focus</div>
            <div class="focus-content">
                <img src="https://upload.wikimedia.org/wikipedia/commons/9/94/Cloudflare_Logo.png" alt="Cloudflare" class="cf-logo" style="filter: brightness(0) invert(1); opacity: 0.8; width: 120px;">
                <h3>Senior Solutions Engineer</h3>
                <p>Evangelizing Zero Trust and Edge Computing architectures. Building the technical footprint in India.</p>
            </div>
            <div class="glow-effect"></div>
        </div>

        <div class="bento-card skills-card" style="grid-area: skills;">
            <div class="card-label">Expertise Toolkit</div>
            <div class="top-skills">
                {skillsHighlihgts.map(skill => <span class="skill-pill highlight">{skill}</span>)}
            </div>
            <div class="other-skills">
                {skillsAll.map(skill => <span class="skill-pill">{skill}</span>)}
            </div>
        </div>

        <div class="bento-card timeline-card" style="grid-area: timeline;">
            <div class="card-header-row">
                <div class="card-label">Career Velocity</div>
                <a href="https://www.linkedin.com/in/tharunraj/" target="_blank" class="linkedin-link">
                    View Full Profile <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                </a>
            </div>
            <div class="timeline-grid">
                {experience.slice(1).map(job => (
                    <div class="mini-job-card" style={`--job-accent: ${job.color}`}>
                        <div class="company-name" style={`color: ${job.color}`}>{job.company}</div>
                        <div class="role-name">{job.role}</div>
                        <div class="job-highlight">{job.highlight}</div>
                    </div>
                ))}
            </div>
        </div>

        <div class="bento-card certs-card" style="grid-area: certs;">
             <div class="card-label">Credentials & Education</div>
             <ul class="cert-list">
                <li>BITS Pilani (BS Info Systems)</li>
                {certs.slice(0,3).map(cert => <li>{cert}</li>)}
             </ul>
        </div>

        <div class="bento-card profile-photo-card" style="grid-area: photo;">
             <img src="/profile.jpg" alt="Tharun Raj Profile" onerror="this.src='https://ui-avatars.com/api/?name=TR&background=111&color=fff'"/>
         </div>

	</main>
    
    <div id="toast" class="toast">Email copied to clipboard!</div>

    <footer>
        <p>Built by Tharun Raj on Cloudflare Pages.</p>
    </footer>
</Layout>

<script>
    // Copy Email Script
    const btn = document.getElementById('copyEmailBtn');
    const toast = document.getElementById('toast');
    const email = "tharun@tharunraj.co.in";

    if (btn && toast) {
        btn.addEventListener('click', () => {
            navigator.clipboard.writeText(email).then(() => {
                toast.classList.add('show');
                setTimeout(() => { toast.classList.remove('show'); }, 3000);
            });
        });
    }
</script>

<style>
    /* --- CSS VARIABLES & GLOBAL --- */
    :root {
        --bg-main: #050505;
        --card-bg: rgba(20, 20, 20, 0.7);
        --card-border: rgba(255, 255, 255, 0.08);
        --text-primary: #ffffff;
        --text-secondary: #a1a1aa;
        --accent-glow: rgba(136, 58, 234, 0.3);
    }

    /* --- LAYOUT GRID --- */
    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem;
        min-height: 90vh;
        display: flex;
        align-items: center;
    }

    /* THE BENTO GRID LAYOUT ENGINE */
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-template-rows: repeat(3, auto);
        gap: 1.5rem;
        /* Desktop Layout Definition */
        grid-template-areas: 
            "hero hero hero focus"
            "skills timeline timeline timeline"
            "skills certs certs photo";
    }

    /* --- BENTO CARD STYLES (The Glassmorphism Look) --- */
    .bento-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 24px;
        padding: 2rem;
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: 0 4px 24px -1px rgba(0,0,0,0.2);
        display: flex;
        flex-direction: column;
    }

    /* The Interactive Hover Effect */
    .bento-card:hover {
        border-color: rgba(255, 255, 255, 0.2);
        transform: translateY(-4px) scale(1.005);
        box-shadow: 0 20px 40px -10px rgba(0,0,0,0.4);
        z-index: 2;
    }
    .bento-card::after { /* Subtle gradient overlay on hover */
        content: ''; position: absolute; inset: 0;
        background: radial-gradient(800px circle at var(--mouse-x, center) var(--mouse-y, center), rgba(255,255,255,0.06), transparent 40%);
        opacity: 0; transition: opacity 0.5s; pointer-events: none;
    }
    .bento-card:hover::after { opacity: 1; }

    /* Card Utilities */
    .card-label {
        font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px;
        color: var(--text-secondary); margin-bottom: 1.5rem; font-weight: 600;
    }

    /* --- SPECIFIC CARD STYLES --- */

    /* HERO CARD (Area 1) */
    .hero-card {
        flex-direction: row; align-items: center; justify-content: space-between;
        background: linear-gradient(135deg, rgba(20,20,20,0.8), rgba(40,40,50,0.8));
    }
    .hero-content { max-width: 60%; z-index: 2; }
    .badge { display: inline-block; padding: 6px 12px; background: rgba(255,255,255,0.1); border-radius: 20px; font-size: 0.8rem; margin-bottom: 1rem; border: 1px solid rgba(255,255,255,0.1); }
    h1 { font-size: 3.5rem; margin: 0; font-weight: 800; letter-spacing: -1px; background: linear-gradient(to right, #fff, #ccc); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    h2 { font-size: 1.5rem; color: #F6821F; margin: 0.5rem 0 1.5rem 0; font-weight: 500; }
    .hero-card p { color: var(--text-secondary); font-size: 1.1rem; margin-bottom: 2rem; max-width: 90%; line-height: 1.6; }
    .hero-image-container {
        position: absolute; right: 0; top: 0; bottom: 0; width: 45%;
        mask-image: linear-gradient(to left, black 60%, transparent 100%); -webkit-mask-image: linear-gradient(to left, black 60%, transparent 100%);
    }
    .hero-img { width: 100%; height: 100%; object-fit: cover; object-position: center top;}

    /* FOCUS CARD (Area 2) */
    .focus-card { background: linear-gradient(160deg, var(--card-bg), rgba(246, 130, 31, 0.15)); justify-content: space-between;}
    .focus-content h3 { font-size: 1.4rem; margin: 1rem 0 0.5rem 0; }
    .focus-content p { color: var(--text-secondary); font-size: 0.95rem; }
    .glow-effect { position: absolute; bottom: 0; right: 0; width: 100px; height: 100px; background: var(--accent); filter: blur(60px); opacity: 0.4; }

    /* SKILLS CARD (Area 3) */
    .skills-card { justify-content: center; }
    .top-skills { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 2rem; }
    .other-skills { display: flex; flex-wrap: wrap; gap: 0.6rem; }
    .skill-pill { padding: 0.5rem 1rem; background: rgba(255,255,255,0.05); border-radius: 8px; font-size: 0.9rem; border: 1px solid var(--card-border); transition: all 0.2s; }
    .skill-pill.highlight { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.25); font-weight: 600; color: #fff; }
    .skill-pill:hover { background: rgba(255,255,255,0.15); transform: translateY(-2px); }

    /* TIMELINE CARD (Area 4) */
    .card-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .linkedin-link { color: var(--text-secondary); text-decoration: none; font-size: 0.9rem; display: flex; align-items: center; gap: 5px; transition: color 0.2s; }
    .linkedin-link:hover { color: #F6821F; }
    .timeline-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
    .mini-job-card { padding: 1.2rem; background: rgba(0,0,0,0.2); border-radius: 12px; border-left: 3px solid var(--job-accent); transition: all 0.2s; }
    .mini-job-card:hover { background: rgba(255,255,255,0.05); transform: translateX(5px); }
    .company-name { font-weight: 700; font-size: 0.9rem; margin-bottom: 0.3rem; }
    .role-name { font-size: 1rem; font-weight: 600; margin-bottom: 0.5rem; }
    .job-highlight { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; }

    /* CERTS CARD (Area 5) */
    .cert-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; }
    .cert-list li { display: flex; align-items: center; gap: 10px; color: var(--text-secondary); font-size: 0.95rem; }
    .cert-list li::before { content: '🏆'; font-size: 1.1rem; }

    /* PHOTO CARD (Area 6) */
    .profile-photo-card { padding: 0; border: 0; }
    .profile-photo-card img { width: 100%; height: 100%; object-fit: cover; border-radius: 24px; transition: transform 0.5s ease;}
    .profile-photo-card:hover img { transform: scale(1.05); }


    /* --- BUTTONS & UI --- */
    .btn-glow {
        position: relative; padding: 0.8rem 1.8rem; background: linear-gradient(to bottom right, #eee, #ccc);
        color: #000; border: none; border-radius: 12px; font-weight: 700; font-size: 1rem; cursor: pointer;
        display: flex; align-items: center; gap: 10px; overflow: hidden; transition: all 0.3s;
    }
    .btn-glow:hover { transform: translateY(-3px); box-shadow: 0 10px 20px -10px rgba(255,255,255,0.5); }
    .toast { visibility: hidden; min-width: 250px; background-color: #333; color: #fff; text-align: center; border-radius: 50px; padding: 16px; position: fixed; z-index: 100; left: 50%; bottom: 30px; transform: translateX(-50%); border: 1px solid rgba(255,255,255,0.1); opacity: 0; transition: opacity 0.5s, bottom 0.5s; }
    .toast.show { visibility: visible; opacity: 1; bottom: 50px; }
    footer { text-align: center; padding: 2rem; color: var(--text-secondary); font-size: 0.8rem; }

    /* --- BACKGROUND FX --- */
    .noise-bg { position: fixed; inset: 0; background: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E"); pointer-events: none; z-index: -1; }
    .blob { position: fixed; width: 500px; height: 500px; border-radius: 50%; filter: blur(100px); opacity: 0.2; z-index: -2; animation: blobFloat 20s infinite alternate ease-in-out; }
    .blob-1 { top: -200px; left: -200px; background: purple; }
    .blob-2 { bottom: -200px; right: -200px; background: orange; animation-delay: -10s; }
    @keyframes blobFloat { 0% { transform: translate(0, 0) scale(1); } 100% { transform: translate(100px, 50px) scale(1.1); } }
    .fade-in { animation: fadeIn 1s ease-out forwards; } @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }


    /* --- RESPONSIVE (MOBILE) --- */
    @media (max-width: 1024px) {
        .container { padding: 1rem; height: auto; display: block;}
        .bento-grid {
            grid-template-columns: 1fr; /* Single column stack */
            grid-template-rows: auto;
            /* Mobile Layout Reordering */
            grid-template-areas: 
                "hero"
                "focus"
                "skills"
                "timeline"
                "certs"
                "photo";
             gap: 1rem;
        }
        .hero-card { flex-direction: column-reverse; padding: 0; overflow: hidden;}
        .hero-image-container { position: relative; width: 100%; height: 300px; mask-image: none; -webkit-mask-image: none; }
        .hero-content { max-width: 100%; padding: 2rem; }
        h1 { font-size: 2.5rem; }
        .bento-card { padding: 1.5rem; }
        .profile-photo-card { display: none; /* Hide secondary photo on mobile to save space */ }
    }
</style>